# EcoCity Tracker — Environment Variables
# ΜΗΝ ανεβάσετε αυτό το αρχείο στο Git

PORT=3000

# JWT Configuration
JWT_SECRET=EcoCitySecretKey2026_SAEK_Aigaleo_@#$
JWT_EXPIRES_IN=7d

# Node environment
NODE_ENV=development

# MySQL (MAMP)
DB_HOST=127.0.0.1
DB_PORT=8889
DB_USER=root
DB_PASSWORD=root
DB_NAME=ecocity

# Email (Gmail — δες οδηγίες παρακάτω)
# 1. Google Account → Security → 2-Step Verification → ενεργοποίησε
# 2. Google Account → Security → App Passwords → Mail → δημιούργησε
# 3. Βάλε το 16-ψήφιο App Password παρακάτω (χωρίς κενά)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-app-password
APP_URL=http://localhost:3000
